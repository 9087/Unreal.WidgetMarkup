<WidgetBlueprint Script='Tests.TestStyleInlineComponent'>
  <StyleSheet>
    <!-- Implicit TextBlock style: all TextBlocks get this by default -->
    <Style TargetType='TextBlock'>
      <Setter Property='Font.Size' RawValue='14' />
      <Setter Property='ColorAndOpacity' RawValue='0.78,0.78,0.78,1' />
    </Style>

    <!-- Table label column style -->
    <Style TargetType='TextBlock' Name='TableLabel'>
      <Setter Property='Font.Size' RawValue='12' />
      <Setter Property='ColorAndOpacity' RawValue='0.5,0.6,0.7,1' />
    </Style>

    <!-- Header: large, bold-appearing, strong white -->
    <Style TargetType='TextBlock' Name='Header'>
      <Setter Property='Font.Size' RawValue='26' />
      <Setter Property='ColorAndOpacity' RawValue='1,1,1,1' />
    </Style>

    <!-- Subtitle: medium, blue-tinted -->
    <Style TargetType='TextBlock' Name='Subtitle'>
      <Setter Property='Font.Size' RawValue='18' />
      <Setter Property='ColorAndOpacity' RawValue='0.6,0.8,1,1' />
    </Style>

    <!-- Body: same size as implicit but higher contrast -->
    <Style TargetType='TextBlock' Name='Body'>
      <Setter Property='ColorAndOpacity' RawValue='0.95,0.95,0.95,1' />
    </Style>

    <!-- Caption: very small, subdued -->
    <Style TargetType='TextBlock' Name='Caption'>
      <Setter Property='Font.Size' RawValue='10' />
      <Setter Property='ColorAndOpacity' RawValue='0.45,0.45,0.45,1' />
    </Style>

    <!-- Link: blue, clickable appearance -->
    <Style TargetType='TextBlock' Name='Link'>
      <Setter Property='Font.Size' RawValue='14' />
      <Setter Property='ColorAndOpacity' RawValue='0.3,0.7,1,1' />
    </Style>

    <!-- Badge: small green label -->
    <Style TargetType='TextBlock' Name='Badge'>
      <Setter Property='Font.Size' RawValue='11' />
      <Setter Property='ColorAndOpacity' RawValue='0.1,0.9,0.4,1' />
    </Style>

    <!-- Warning: orange alert text -->
    <Style TargetType='TextBlock' Name='Warning'>
      <Setter Property='Font.Size' RawValue='14' />
      <Setter Property='ColorAndOpacity' RawValue='1,0.65,0.15,1' />
    </Style>

    <!-- Card: dark bordered panel -->
    <Style TargetType='Border' Name='Card'>
      <Setter Property='BrushColor' RawValue='0.12,0.12,0.14,1' />
      <Setter Property='Padding.Left' RawValue='12' />
      <Setter Property='Padding.Top' RawValue='8' />
      <Setter Property='Padding.Right' RawValue='12' />
      <Setter Property='Padding.Bottom' RawValue='8' />
    </Style>

    <!-- AccentCard: blue-tinted panel -->
    <Style TargetType='Border' Name='AccentCard'>
      <Setter Property='BrushColor' RawValue='0.08,0.14,0.22,1' />
      <Setter Property='Padding.Left' RawValue='16' />
      <Setter Property='Padding.Top' RawValue='12' />
      <Setter Property='Padding.Right' RawValue='16' />
      <Setter Property='Padding.Bottom' RawValue='12' />
    </Style>
  </StyleSheet>
  <WidgetTree>
    <ScrollBox>
      <GridPanel>
        <!-- Title row: spans both columns -->
        <TextBlock Name='HeaderText' Text='Style Preview'
                   Slot.Row='0' Slot.Column='0' Slot.ColumnSpan='2'
                   Style='Header' />
        <TextBlock Name='CaptionText' Text='Typography scale, semantic colors, and container styles'
                   Slot.Row='1' Slot.Column='0' Slot.ColumnSpan='2'
                   Style='Caption' />

        <!-- ===== Typography section ===== -->
        <TextBlock Text='Typography' Style='Subtitle'
                   Slot.Row='2' Slot.Column='0' Slot.ColumnSpan='2' />

        <!-- Row: Header -->
        <TextBlock Name='LabelHeader' Text='Header' Style='TableLabel'
                   Slot.Row='3' Slot.Column='0' />
        <TextBlock Name='PreviewHeader' Text='The quick brown fox jumps over the lazy dog'
                   Style='Header'
                   Slot.Row='3' Slot.Column='1' />

        <!-- Row: Subtitle -->
        <TextBlock Name='LabelSubtitle' Text='Subtitle' Style='TableLabel'
                   Slot.Row='4' Slot.Column='0' />
        <TextBlock Name='PreviewSubtitle' Text='The quick brown fox jumps over the lazy dog'
                   Style='Subtitle'
                   Slot.Row='4' Slot.Column='1' />

        <!-- Row: Body -->
        <TextBlock Name='LabelBody' Text='Body' Style='TableLabel'
                   Slot.Row='5' Slot.Column='0' />
        <TextBlock Name='PreviewBody' Text='The quick brown fox jumps over the lazy dog'
                   Style='Body'
                   Slot.Row='5' Slot.Column='1' />

        <!-- Row: Implicit (default) -->
        <TextBlock Name='LabelImplicit' Text='Default (implicit)' Style='TableLabel'
                   Slot.Row='6' Slot.Column='0' />
        <TextBlock Name='PreviewImplicit' Text='The quick brown fox jumps over the lazy dog'
                   Slot.Row='6' Slot.Column='1' />

        <!-- Row: Caption -->
        <TextBlock Name='LabelCaption' Text='Caption' Style='TableLabel'
                   Slot.Row='7' Slot.Column='0' />
        <TextBlock Name='PreviewCaption' Text='The quick brown fox jumps over the lazy dog'
                   Style='Caption'
                   Slot.Row='7' Slot.Column='1' />

        <!-- ===== Semantic colors section ===== -->
        <TextBlock Text='Semantic Colors' Style='Subtitle'
                   Slot.Row='8' Slot.Column='0' Slot.ColumnSpan='2' />

        <!-- Row: Link -->
        <TextBlock Name='LabelLink' Text='Link' Style='TableLabel'
                   Slot.Row='9' Slot.Column='0' />
        <TextBlock Name='PreviewLink' Text='→ View documentation'
                   Style='Link'
                   Slot.Row='9' Slot.Column='1' />

        <!-- Row: Badge -->
        <TextBlock Name='LabelBadge' Text='Badge' Style='TableLabel'
                   Slot.Row='10' Slot.Column='0' />
        <TextBlock Name='PreviewBadge' Text='  ACTIVE  ' Style='Badge'
                   Slot.Row='10' Slot.Column='1' />

        <!-- Row: Warning -->
        <TextBlock Name='LabelWarning' Text='Warning' Style='TableLabel'
                   Slot.Row='11' Slot.Column='0' />
        <TextBlock Name='PreviewWarning' Text='⚠ Configuration requires attention'
                   Style='Warning'
                   Slot.Row='11' Slot.Column='1' />

        <!-- ===== Container styles section ===== -->
        <TextBlock Text='Containers' Style='Subtitle'
                   Slot.Row='12' Slot.Column='0' Slot.ColumnSpan='2' />

        <!-- Row: Card -->
        <TextBlock Name='LabelCard' Text='Card' Style='TableLabel'
                   Slot.Row='13' Slot.Column='0' />
        <Border Name='PreviewCard' Style='Card'
                Slot.Row='13' Slot.Column='1' />

        <!-- Row: AccentCard -->
        <TextBlock Name='LabelAccentCard' Text='AccentCard' Style='TableLabel'
                   Slot.Row='14' Slot.Column='0' />
        <Border Name='PreviewAccentCard' Style='AccentCard'
                Slot.Row='14' Slot.Column='1' />
      </GridPanel>
    </ScrollBox>
  </WidgetTree>
</WidgetBlueprint>